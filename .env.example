# ─── Vercel (Environment Variables) ───
# Settings → Environment Variables → Production + Preview

# Supabase (Project Settings → API)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # service_role — só no servidor, nunca no frontend

# Chave compartilhada pelo time (invente uma string longa)
REPORTS_API_KEY=sua-chave-secreta-aqui

# Mesma chave no build do frontend (Vite expõe só variáveis VITE_*)
VITE_REPORTS_API_KEY=sua-chave-secreta-aqui

# (Opcional) Fixar planilha de horas para auto-conectar no frontend
# Use URL do Apps Script Web App (/exec) para suportar múltiplas abas.
VITE_HORAS_SHEETS_URL=
VITE_HORAS_SHEETS_METHOD=appscript
# Nome da aba inicial (ex.: ABRIL). Deixe vazio para escolha automática.
VITE_HORAS_SHEETS_DEFAULT_TAB=
